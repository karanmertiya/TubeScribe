# ═══════════════════════════════════════════════════════
# TubeScribe — Environment Configuration
# cp .env.example .env  →  fill in values  →  docker compose up
# ═══════════════════════════════════════════════════════

# ── Developer auth ───────────────────────────────────────
ADMIN_PASSWORD=change_me_please
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=

# ── LLM — server-side keys (developer mode) ──────────────
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Developer Telegram ────────────────────────────────────
# Create a bot: https://t.me/BotFather  → /newbot
# Get your chat ID: message @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Deployment ────────────────────────────────────────────
# Your public URL (used in Telegram messages, etc.)
BASE_URL=https://your-app.railway.app
# Set true if behind HTTPS (enables secure cookie flag)
HTTPS=true

# ── Storage ───────────────────────────────────────────────
# Where analytics.db is written. On Railway, use a volume mount path.
DATA_DIR=/data

# ── Pipeline tuning ───────────────────────────────────────
CHUNK_WORDS=700
GROQ_RETRY_WAIT=15
TG_MAX_MB=49
